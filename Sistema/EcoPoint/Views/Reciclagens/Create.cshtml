@model EcoPoint.Models.Reciclagem

@{
    ViewData["Title"] = "Nova Reciclagem";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow border-0"
                 style="border-radius:20px;">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h1 class="fw-bold"
                            style="color:#1D3557;">
                            ♻️ Nova Reciclagem
                        </h1>

                        <p style="color:#457B9D;">
                            Registre materiais reciclados e gere pontos.
                        </p>

                    </div>

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="mb-4">

                            <label asp-for="UsuarioId"
                                   class="form-label fw-bold">
                                Usuário
                            </label>

                            <select asp-for="UsuarioId"
                                    class="form-select"
                                    asp-items="ViewBag.UsuarioId">
                            </select>

                        </div>

                        <div class="mb-4">

                            <label asp-for="EcopontoId"
                                   class="form-label fw-bold">
                                Ecoponto
                            </label>

                            <select asp-for="EcopontoId"
                                    class="form-select"
                                    asp-items="ViewBag.EcopontoId">
                            </select>

                        </div>

                        <div class="mb-4">

                            <label asp-for="TipoMaterialId"
                                   class="form-label fw-bold">
                                Tipo de Material
                            </label>

                            <select asp-for="TipoMaterialId"
                                    class="form-select"
                                    asp-items="ViewBag.TipoMaterialId">
                            </select>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Peso"
                                   class="form-label fw-bold">
                                Peso (kg)
                            </label>

                            <input asp-for="Peso"
                                   class="form-control"
                                   placeholder="Digite o peso reciclado" />

                            <span asp-validation-for="Peso"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="d-grid gap-3">

                            <button type="submit"
                                    class="btn btn-lg fw-bold text-white"
                                    style="background-color:#2A9D8F;
                                           border-radius:12px;">

                                Registrar Reciclagem

                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Voltar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}