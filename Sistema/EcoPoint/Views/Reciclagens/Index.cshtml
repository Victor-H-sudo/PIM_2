@model IEnumerable<EcoPoint.Models.Reciclagem>

@{
    ViewData["Title"] = "Reciclagens";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold" style="color:#1D3557;">
                ♻️ Reciclagens
            </h1>

            <p style="color:#457B9D;">
                Registre e acompanhe as reciclagens realizadas.
            </p>
        </div>

        <a asp-action="Create"
           class="btn fw-bold text-white"
           style="background-color:#2A9D8F; border-radius:12px;">
            + Nova Reciclagem
        </a>
    </div>

    <div class="card shadow border-0 p-4"
         style="border-radius:20px; background-color:#FFFFFF;">

        <table class="table table-hover align-middle">

            <thead>
                <tr style="color:#1D3557;">
                    <th>Usuário</th>
                    <th>Ecoponto</th>
                    <th>Material</th>
                    <th>Peso</th>
                    <th>Pontos</th>
                    <th>Data</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">
                            @(item.Usuario?.Nome ?? "Não informado")
                        </td>

                        <td>
                            @(item.Ecoponto?.Nome ?? "Não informado")
                        </td>

                        <td>
                            @(item.TipoMaterial?.Nome ?? "Não informado")
                        </td>

                        <td>
                            @item.Peso kg
                        </td>

                        <td>
                            <span class="badge"
                                  style="background-color:#1D3557;">
                                ⭐ @item.PontosGerados
                            </span>
                        </td>

                        <td>
                            @item.Data.ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">
                                Ver
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger">
                                Remover
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>