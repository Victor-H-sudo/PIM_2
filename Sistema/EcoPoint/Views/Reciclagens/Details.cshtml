@model EcoPoint.Models.Reciclagem

@{
    ViewData["Title"] = "Detalhes da Reciclagem";
}

<div class="container mt-5">

    <div class="card shadow border-0 p-5"
         style="border-radius:20px;">

        <h1 class="fw-bold mb-4"
            style="color:#1D3557;">
            ♻️ Detalhes da Reciclagem
        </h1>

        <div class="mb-3">
            <strong>Usuário:</strong>
            @(Model.Usuario?.Nome ?? "Não informado")
        </div>

        <div class="mb-3">
            <strong>Ecoponto:</strong>
            @(Model.Ecoponto?.Nome ?? "Não informado")
        </div>

        <div class="mb-3">
            <strong>Material:</strong>
            @(Model.TipoMaterial?.Nome ?? "Não informado")
        </div>

        <div class="mb-3">
            <strong>Peso:</strong>
            @Model.Peso kg
        </div>

        <div class="mb-3">
            <strong>Pontos gerados:</strong>
            <span class="badge"
                  style="background-color:#1D3557;">
                ⭐ @Model.PontosGerados
            </span>
        </div>

        <div class="mb-4">
            <strong>Data:</strong>
            @Model.Data.ToString("dd/MM/yyyy")
        </div>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            Voltar
        </a>

    </div>

</div>