@model EcoPoint.Models.Reciclagem

@{
    ViewData["Title"] = "Excluir Reciclagem";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-7">

            <div class="card shadow border-0"
                 style="border-radius:20px; overflow:hidden;">

                <div class="text-center p-5"
                     style="background-color:#E63946;">

                    <i class="fa-solid fa-trash fa-5x text-white"></i>

                </div>

                <div class="card-body p-5">

                    <h1 class="fw-bold mb-4 text-center"
                        style="color:#1D3557;">
                        Excluir Reciclagem
                    </h1>

                    <p class="lead text-center mb-5">
                        Tem certeza que deseja remover esta reciclagem?
                    </p>

                    <div class="mb-3">
                        <strong>Usuário:</strong>
                        @(Model.Usuario?.Nome ?? "Não informado")
                    </div>

                    <div class="mb-3">
                        <strong>Ecoponto:</strong>
                        @(Model.Ecoponto?.Nome ?? "Não informado")
                    </div>

                    <div class="mb-3">
                        <strong>Material:</strong>
                        @(Model.TipoMaterial?.Nome ?? "Não informado")
                    </div>

                    <div class="mb-3">
                        <strong>Peso:</strong>
                        @Model.Peso kg
                    </div>

                    <div class="mb-4">
                        <strong>Pontos:</strong>

                        <span class="badge"
                              style="background-color:#1D3557;">
                            ⭐ @Model.PontosGerados
                        </span>
                    </div>

                    <form asp-action="Delete">

                        <input type="hidden"
                               asp-for="Id" />

                        <div class="d-grid gap-3">

                            <button type="submit"
                                    class="btn btn-lg btn-danger fw-bold">

                                Excluir

                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Cancelar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>