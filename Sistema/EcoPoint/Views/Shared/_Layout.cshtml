<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EcoPoint</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>

<body style="background-color:#F1FAEE;">

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm"
             style="background-color:#1D3557;">

            <div class="container">

                <a class="navbar-brand fw-bold"
                   asp-controller="Home"
                   asp-action="Index">

                    <i class="fa-solid fa-recycle"></i>
                    EcoPoint

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#menu">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="menu"><ul class="navbar-nav me-auto mb-2 mb-lg-0">

    @if (Context.Session.GetString("UsuarioNome") != null)
    {
        <li class="nav-item">
            <a class="nav-link"
               asp-controller="Home"
               asp-action="Index">
                <i class="fa-solid fa-house"></i>
                Home
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link"
               asp-controller="Usuarios"
               asp-action="Ranking">
                <i class="fa-solid fa-trophy"></i>
                Ranking
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link"
               asp-controller="Recompensas"
               asp-action="Loja">
                <i class="fa-solid fa-gift"></i>
                Recompensas
            </a>
        </li>

        @if (Context.Session.GetString("TipoUsuario") == "Empresa"
            || Context.Session.GetString("TipoUsuario") == "Admin")
        {
            <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Reciclagens"
                   asp-action="Index">
                    <i class="fa-solid fa-recycle"></i>
                    Reciclagens
                </a>
            </li>
        }

        @if (Context.Session.GetString("TipoUsuario") == "Admin")
        {
            <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Usuarios"
                   asp-action="Index">
                    <i class="fa-solid fa-users"></i>
                    Usuários
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Usuarios"
                   asp-action="CriarEmpresa">
                    <i class="fa-solid fa-building"></i>
                    Empresas
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Recompensas"
                   asp-action="Index">
                    <i class="fa-solid fa-sliders"></i>
                    Gerenciar
                </a>
            </li>
        }
    }

</ul><ul class="navbar-nav ms-auto">

    @if (Context.Session.GetString("UsuarioNome") != null)
    {
        <li class="nav-item">
            <span class="nav-link text-light">
                <i class="fa-solid fa-user"></i>
                @Context.Session.GetString("UsuarioNome")
            </span>
        </li>

        <li class="nav-item">
            <span class="nav-link text-warning">
                @Context.Session.GetString("TipoUsuario")
            </span>
        </li>

        <li class="nav-item">
            <a class="nav-link text-danger fw-bold"
               asp-controller="Login"
               asp-action="Logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                Sair
            </a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-light"
               asp-controller="Login"
               asp-action="Index">
                <i class="fa-solid fa-right-to-bracket"></i>
                Login
            </a>
        </li>
    }

</ul>                </div>

            </div>

        </nav>

    </header>

    <div class="container mt-4">

        <main role="main" class="pb-3">

            @if (TempData["Sucesso"] != null)
            {
                <div class="alert alert-success text-center shadow-sm">
                    @TempData["Sucesso"]
                </div>
            }

            @if (TempData["Erro"] != null)
            {
                <div class="alert alert-danger text-center shadow-sm">
                    @TempData["Erro"]
                </div>
            }

            @RenderBody()

        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>