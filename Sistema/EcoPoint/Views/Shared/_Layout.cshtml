<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EcoPoint</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body style="background-color:#F4F1EA;">

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark shadow-sm"
             style="background-color:#1D3557;">

            <div class="container-fluid">

                <a class="navbar-brand fw-bold text-white"
                   asp-controller="Home"
                   asp-action="Index">
                    ECOPOINT
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Usuarios"
                               asp-action="Ranking">
                                Ranking
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Recompensas"
                               asp-action="Loja">
                                Recompensas
                            </a>
                        </li>

                        @if (Context.Session.GetString("TipoUsuario") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold"
                                   asp-controller="Usuarios"
                                   asp-action="Index">
                                    Painel Admin
                                </a>
                            </li>
                        }

                        @if (Context.Session.GetString("TipoUsuario") == "Empresa"
                        || Context.Session.GetString("TipoUsuario") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold"
                                   asp-controller="Reciclagens"
                                   asp-action="Index">
                                    Reciclagens
                                </a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">

                        @if (Context.Session.GetString("UsuarioNome") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    👤 @Context.Session.GetString("UsuarioNome")
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger"
                                   asp-controller="Login"
                                   asp-action="Logout">
                                    Sair
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light"
                                   asp-controller="Login"
                                   asp-action="Index">
                                    Login
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
            @if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success text-center mt-3">
        @TempData["Sucesso"]
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger text-center mt-3">
        @TempData["Erro"]
    </div>
}
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>