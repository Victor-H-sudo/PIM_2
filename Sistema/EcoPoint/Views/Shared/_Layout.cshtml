@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoPoint</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EcoPoint.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <ul class="navbar-nav flex-grow-1">

    @if (Context.Session.GetString("TipoUsuario") == "Admin")
    {
        <li class="nav-item">
            <a class="nav-link text-light"
               asp-controller="Usuarios"
               asp-action="Index">
               Usuários
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link text-light"
               asp-controller="Ecopontos"
               asp-action="Index">
               Ecopontos
            </a>
        </li>
    }

    @if (Context.Session.GetString("TipoUsuario") == "Empresa")
    {
        <li class="nav-item">
            <a class="nav-link text-light"
               asp-controller="Reciclagens"
               asp-action="Index">
               Reciclagens
            </a>
        </li>
    }

    @if (Context.Session.GetString("TipoUsuario") == "Usuario")
    {
        <li class="nav-item">
            <a class="nav-link text-light"
               asp-controller="Usuarios"
               asp-action="Ranking">
               Ranking
            </a>
        </li>
    }

    @if (Context.Session.GetString("UsuarioNome") != null)
    {
        <li class="nav-item">
            <a class="nav-link text-light"
               asp-controller="Login"
               asp-action="Logout">
               Sair
            </a>
        </li>
    }

</ul>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - EcoPoint - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
