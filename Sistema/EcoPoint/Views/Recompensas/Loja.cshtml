@model IEnumerable<EcoPoint.Models.Recompensa>

@{
    ViewData["Title"] = "Loja de Recompensas";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold"
            style="color:#1D3557;">
            🎁 Loja de Recompensas
        </h1>

        <p class="lead"
           style="color:#457B9D;">
            Troque seus pontos por recompensas exclusivas.
        </p>

    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4">

                <div class="card shadow border-0 h-100"
                     style="border-radius:20px; overflow:hidden;">

                    @if (item.Nome.Contains("Gela"))
                    {
                        <div class="text-center p-4"
                             style="background:linear-gradient(135deg,#FF006E,#FFD60A);">

                            <i class="fa-solid fa-key fa-4x text-white"></i>

                        </div>
                    }
                    else
                    {
                        <div class="text-center p-4"
                             style="background-color:#2A9D8F;">

                            <i class="fa-solid fa-gift fa-4x text-white"></i>

                        </div>
                    }

                    <div class="card-body d-flex flex-column">

                        <h3 class="fw-bold"
                            style="color:#1D3557;">
                            @item.Nome
                        </h3>

                        <p class="text-muted">
                            @item.Descricao
                        </p>

                        <div class="mt-auto">

                            <div class="mb-3">

                                <span class="badge fs-6 p-3"
                                      style="background-color:#1D3557;">

                                    ⭐ @item.PontosNecessarios pontos

                                </span>

                            </div>

                            <form asp-controller="Recompensas"
                                  asp-action="Resgatar"
                                  method="post">

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <button type="submit"
                                        class="btn w-100 fw-bold text-dark"
                                        style="background-color:#FFD60A;
                                               border-radius:12px;">

                                    Resgatar

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>