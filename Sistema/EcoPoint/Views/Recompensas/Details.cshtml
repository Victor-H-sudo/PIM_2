@model EcoPoint.Models.Recompensa

@{
    ViewData["Title"] = "Detalhes da Recompensa";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow border-0"
                 style="border-radius:20px; overflow:hidden;">

                @if (Model.Nome.Contains("Gela"))
                {
                    <div class="text-center p-5"
                         style="background:linear-gradient(135deg,#FF006E,#FFD60A);">

                        <i class="fa-solid fa-key fa-5x text-white"></i>

                    </div>
                }
                else
                {
                    <div class="text-center p-5"
                         style="background-color:#2A9D8F;">

                        <i class="fa-solid fa-gift fa-5x text-white"></i>

                    </div>
                }

                <div class="card-body p-5">

                    <h1 class="fw-bold mb-4"
                        style="color:#1D3557;">
                        @Model.Nome
                    </h1>

                    <div class="mb-4">

                        <h5 class="fw-bold">
                            Descrição
                        </h5>

                        <p class="text-muted">
                            @Model.Descricao
                        </p>

                    </div>

                    <div class="mb-4">

                        <h5 class="fw-bold">
                            Pontos necessários
                        </h5>

                        <span class="badge fs-5 p-3"
                              style="background-color:#1D3557;">

                            ⭐ @Model.PontosNecessarios pontos

                        </span>

                    </div>

                    <div class="d-grid gap-3">

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Voltar

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>