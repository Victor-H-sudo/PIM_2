@model EcoPoint.Models.Recompensa

@{
    ViewData["Title"] = "Excluir Recompensa";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-7">

            <div class="card shadow border-0"
                 style="border-radius:20px; overflow:hidden;">

                <div class="text-center p-5"
                     style="background-color:#E63946;">

                    <i class="fa-solid fa-trash fa-5x text-white"></i>

                </div>

                <div class="card-body p-5 text-center">

                    <h1 class="fw-bold mb-4"
                        style="color:#1D3557;">
                        Excluir Recompensa
                    </h1>

                    <p class="lead">
                        Tem certeza que deseja excluir:
                    </p>

                    <h3 class="fw-bold mb-4"
                        style="color:#E63946;">
                        @Model.Nome
                    </h3>

                    <div class="mb-4">

                        <span class="badge fs-5 p-3"
                              style="background-color:#1D3557;">

                            ⭐ @Model.PontosNecessarios pontos

                        </span>

                    </div>

                    <form asp-action="Delete">

                        <input type="hidden"
                               asp-for="Id" />

                        <div class="d-grid gap-3">

                            <button type="submit"
                                    class="btn btn-lg btn-danger fw-bold">

                                Excluir

                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Cancelar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>