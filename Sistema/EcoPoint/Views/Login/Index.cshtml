@model EcoPoint.ViewModels.LoginViewModel

<h2>Login</h2>

<form asp-action="Index">

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Senha</label>
        <input asp-for="Senha" type="password" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Entrar
    </button>

</form>

<p style="color:red">
    @ViewBag.Erro
</p>