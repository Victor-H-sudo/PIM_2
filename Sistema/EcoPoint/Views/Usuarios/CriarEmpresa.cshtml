@model EcoPoint.Models.Usuario

@{
    ViewData["Title"] = "Cadastrar Empresa";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow border-0"
                 style="border-radius:20px;">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h1 class="fw-bold"
                            style="color:#1D3557;">
                            🏢 Nova Empresa
                        </h1>

                        <p style="color:#457B9D;">
                            Cadastre parceiros e ecopontos do EcoPoint.
                        </p>

                    </div>

                    <form asp-action="CriarEmpresa">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="mb-4">

                            <label asp-for="Nome"
                                   class="form-label fw-bold">
                                Nome da empresa
                            </label>

                            <input asp-for="Nome"
                                   class="form-control"
                                   placeholder="Digite o nome da empresa" />

                        </div>

                        <div class="mb-4">

                            <label asp-for="CPF"
                                   class="form-label fw-bold">
                                CNPJ
                            </label>

                            <input asp-for="CPF"
                                   class="form-control"
                                   placeholder="Digite o CNPJ" />

                        </div>

                        <div class="mb-4">

                            <label asp-for="Email"
                                   class="form-label fw-bold">
                                Email
                            </label>

                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="Digite o email" />

                        </div>

                        <div class="mb-4">

                            <label asp-for="Senha"
                                   class="form-label fw-bold">
                                Senha
                            </label>

                            <input asp-for="Senha"
                                   type="password"
                                   class="form-control"
                                   placeholder="Digite a senha" />

                        </div>

                        <div class="d-grid gap-3">

                            <button type="submit"
                                    class="btn btn-lg fw-bold text-white"
                                    style="background-color:#2A9D8F;
                                           border-radius:12px;">

                                Cadastrar Empresa

                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Voltar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}