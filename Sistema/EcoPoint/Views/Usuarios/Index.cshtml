@model IEnumerable<EcoPoint.Models.Usuario>

@{
    ViewData["Title"] = "Usuários";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold" style="color:#1D3557;">
                👥 Usuários
            </h1>

            <p style="color:#457B9D;">
                Gerencie usuários e empresas cadastradas.
            </p>
        </div>

        <a asp-action="CriarEmpresa"
           class="btn fw-bold text-dark"
           style="background-color:#FFD60A; border-radius:12px;">
            + Cadastrar Empresa
        </a>
    </div>

    <div class="card shadow border-0 p-4"
         style="border-radius:20px; background-color:#FFFFFF;">

        <table class="table table-hover align-middle">

            <thead>
                <tr style="color:#1D3557;">
                    <th>Nome</th>
                    <th>CPF / CNPJ</th>
                    <th>Email</th>
                    <th>Perfil</th>
                    <th>Pontos</th>
                    <th>Cadastro</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Nome</td>
                        <td>@item.CPF</td>
                        <td>@item.Email</td>

                        <td>
                            @if (item.TipoUsuario == "Admin")
                            {
                                <span class="badge bg-warning text-dark">Admin</span>
                            }
                            else if (item.TipoUsuario == "Empresa")
                            {
                                <span class="badge bg-success">Empresa</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Usuário</span>
                            }
                        </td>

                        <td>
                            <span class="badge"
                                  style="background-color:#1D3557;">
                                ⭐ @item.Pontos
                            </span>
                        </td>

                        <td>@item.DataCadastro.ToShortDateString()</td>

                        <td>
                            <a asp-controller="Usuarios"
                            asp-action="Details"
                            asp-route-id="@item.Id"
                            class="btn btn-sm btn-outline-primary">
                                Ver
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger">
                                Remover
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>