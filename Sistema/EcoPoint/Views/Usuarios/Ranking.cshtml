@model IEnumerable<EcoPoint.Models.Usuario>

@{
    ViewData["Title"] = "Ranking";
}

<h2 style="color:#1D3557;">🏆 Ranking</h2>

@foreach (var item in Model)
{
    <div class="card p-3 mb-3" style="background-color:#F1FAEE; border-radius:18px;">
        <h4 style="color:#1D3557;">@item.Nome</h4>
        <p style="color:#333;">Pontos: <strong>@item.Pontos</strong></p>
    </div>
}
