@model IEnumerable<EcoPoint.Models.Usuario>

@{
    ViewData["Title"] = "Ranking";
    int posicao = 1;
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold" style="color:#1D3557;">
            🏆 Ranking de Usuários
        </h1>

        <p class="lead" style="color:#457B9D;">
            Usuários com mais pontos acumulados no EcoPoint.
        </p>

        <a asp-controller="Recompensas"
           asp-action="Loja"
           class="btn fw-bold text-dark"
           style="background-color:#FFD60A; border-radius:12px;">
            Trocar pontos por recompensas
        </a>
    </div>

    @foreach (var item in Model)
    {
        string cor = "#FFFFFF";
        string medalha = "♻️";

        if (posicao == 1)
        {
            cor = "#2A9D8F";
            medalha = "🥇";
        }
        else if (posicao == 2)
        {
            cor = "#A8DADC";
            medalha = "🥈";
        }
        else if (posicao == 3)
        {
            cor = "#F1FAEE";
            medalha = "🥉";
        }

        <div class="card shadow border-0 mb-3"
             style="border-radius:20px; background-color:@cor;">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>
                    <h3 class="fw-bold" style="color:#1D3557;">
                        @medalha @(posicao)º - @item.Nome
                    </h3>

                    <p class="mb-0" style="color:#333;">
                        CPF: @item.CPF
                    </p>
                </div>

                <div>
                    <span class="badge fs-5 p-3"
                          style="background-color:#1D3557;">
                        ⭐ @item.Pontos pontos
                    </span>
                </div>

            </div>

        </div>

        posicao++;
    }

</div>