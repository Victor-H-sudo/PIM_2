@{
    int posicao = 1;
}

@foreach (var item in Model)
{
    var classe = "";

    if (posicao == 1) classe = "rank-1";
    else if (posicao == 2) classe = "rank-2";
    else if (posicao == 3) classe = "rank-3";

    <div class="card @classe">
        <h3>@item.Nome</h3>
        <p>CPF: @item.CPF</p>
        <p><b>Pontos: @item.Pontos</b></p>
    </div>

    posicao++;
}