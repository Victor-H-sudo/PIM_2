@model IEnumerable<EcoPoint.Models.Ecoponto>

@{
    ViewData["Title"] = "Ecopontos";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold" style="color:#1D3557;">
                🏢 Ecopontos
            </h1>

            <p style="color:#457B9D;">
                Gerencie os pontos parceiros de coleta.
            </p>
        </div>

        <a asp-action="Create"
           class="btn fw-bold text-white"
           style="background-color:#2A9D8F; border-radius:12px;">
            + Novo Ecoponto
        </a>
    </div>

    <div class="card shadow border-0 p-4"
         style="border-radius:20px; background-color:#FFFFFF;">

        <table class="table table-hover align-middle">

            <thead>
                <tr style="color:#1D3557;">
                    <th>Nome</th>
                    <th>CNPJ</th>
                    <th>Email</th>
                    <th>Endereço</th>
                    <th>Maps</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Nome</td>
                        <td>@item.CNPJ</td>
                        <td>@item.Email</td>
                        <td>@item.Endereco</td>

                        <td>
                            @if (!string.IsNullOrEmpty(item.LinkMaps))
                            {
                                <a href="@item.LinkMaps"
                                   target="_blank"
                                   class="btn btn-sm btn-outline-success">
                                    Abrir
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Não informado</span>
                            }
                        </td>

                        <td>
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">
                                Ver
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger">
                                Remover
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>