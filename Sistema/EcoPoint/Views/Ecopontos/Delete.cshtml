@model EcoPoint.Models.Ecoponto

@{
    ViewData["Title"] = "Excluir Ecoponto";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-7">

            <div class="card shadow border-0"
                 style="border-radius:20px; overflow:hidden;">

                <div class="text-center p-5"
                     style="background-color:#E63946;">

                    <i class="fa-solid fa-building-circle-xmark fa-5x text-white"></i>

                </div>

                <div class="card-body p-5 text-center">

                    <h1 class="fw-bold mb-4"
                        style="color:#1D3557;">
                        Excluir Ecoponto
                    </h1>

                    <p class="lead">
                        Tem certeza que deseja remover este ecoponto?
                    </p>

                    <h3 class="fw-bold mb-4"
                        style="color:#E63946;">
                        @Model.Nome
                    </h3>

                    <p>
                        <strong>CNPJ:</strong>
                        @Model.CNPJ
                    </p>

                    <p>
                        <strong>Email:</strong>
                        @Model.Email
                    </p>

                    <p>
                        <strong>Endereço:</strong>
                        @Model.Endereco
                    </p>

                    <form asp-action="Delete">

                        <input type="hidden"
                               asp-for="Id" />

                        <div class="d-grid gap-3 mt-4">

                            <button type="submit"
                                    class="btn btn-lg btn-danger fw-bold">

                                Excluir

                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Cancelar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>